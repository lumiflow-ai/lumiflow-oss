{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/entrypoint.ts",
  "type": "module",
  "scripts": {
    "build": "npm run generate:types && npx tsc",
    "start": "tsx src/entrypoint.ts",
    "dev": "npm run generate:types && NODE_ENV='development' tsx watch src/entrypoint.ts",
    "dev:services": "docker compose -f dev-services/compose.yaml up -d",
    "lint": "npx @biomejs/biome check",
    "format": "npx @biomejs/biome check --error-on-warnings --write",
    "forceFormat": "npx @biomejs/biome check --error-on-warnings --fix --unsafe",
    "generate:types": "tsx src/scripts/generate-types.ts src/types.ts && npx @biomejs/biome check --write src/types.ts",
    "generate:client-types": "bash scripts/generate-client-types.sh",
    "pre-commit": "bash scripts/pre-commit.sh",
    "prepare": "bash scripts/install-git-hooks.sh",
    "test": "vitest",
    "typecheck": "npm run generate:types && tsc",
    "seed:metrics": "tsx src/scripts/seed-artifact-metrics.ts",
    "db:migrate": "tsx src/scripts/migrate-database.ts",
    "db:clear-except-artifacts": "tsx src/scripts/clear-everything-except-artifacts.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "better-auth": "^1.6.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "dotenv-safe": "^8.2.0",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "helmet": "^7.1.0",
    "lodash": "^4.17.21",
    "pg": "^8.11.3",
    "pino": "^9.14.0",
    "zod": "^3.23.8",
    "zod-to-ts": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.1",
    "@types/cors": "^2.8.17",
    "@types/diff": "^5.2.1",
    "@types/dotenv-safe": "^8.1.5",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.17",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
