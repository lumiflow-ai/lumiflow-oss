{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:release": "next build && next start",
    "build": "next build",
    "start": "next start",
    "lint": "npx @biomejs/biome check",
    "format": "npx @biomejs/biome check --error-on-warnings --write",
    "forceFormat": "npx @biomejs/biome check --error-on-warnings --fix --unsafe",
    "pre-commit": "bash scripts/pre-commit.sh",
    "prepare": "bash scripts/install-git-hooks.sh",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:snapshot": "vitest --project snapshot",
    "test:snapshot:update": "vitest --project snapshot --update",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "geist": "^1.3.1",
    "js-colormaps-es": "^0.0.5",
    "lodash": "^4.18.1",
    "next": "^15.5.14",
    "papaparse": "^5.5.3",
    "pino": "^9.13.1",
    "react": "^18",
    "react-dom": "^18",
    "recoil": "^0.7.7",
    "styled-components": "^6.1.12",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.1",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22",
    "@types/papaparse": "^5.5.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser": "^4.0.15",
    "@vitest/browser-playwright": "^4.0.15",
    "playwright": "^1.57.0",
    "typescript": "^5.5.4",
    "vitest": "^4.0.15",
    "vitest-browser-react": "^2.0.0"
  }
}
