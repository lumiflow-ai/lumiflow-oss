{
  "name": "job-service",
  "version": "0.1.0",
  "main": "src/entrypoint.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npx tsc",
    "start": "tsx src/entrypoint.ts",
    "dev": "NODE_ENV='development' tsx watch src/entrypoint.ts",
    "lint": "npx @biomejs/biome check",
    "format": "npx @biomejs/biome check --error-on-warnings --write",
    "forceFormat": "npx @biomejs/biome check --error-on-warnings --fix --unsafe",
    "generate-types": "tsx src/scripts/generate-types.ts",
    "pre-commit": "bash scripts/pre-commit.sh",
    "prepare": "bash scripts/install-git-hooks.sh",
    "dev:docker": "bash scripts/start-database-container.sh",
    "test": "NODE_ENV='test' vitest",
    "typecheck": "npm run generate-types && tsc",
    "db:migrate": "tsx src/scripts/migrate-database.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.1",
    "@types/pg": "^8.11.11",
    "@types/yaml": "^1.9.7",
    "dotenv": "^16.3.1",
    "dotenv-safe": "^8.2.0",
    "express": "^4.18.2",
    "lodash": "^4.17.21",
    "pg": "^8.13.1",
    "pino": "^9.14.0",
    "zod": "^3.23.8",
    "zod-to-ts": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.1",
    "@types/dotenv-safe": "^8.1.5",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.7",
    "@types/node": "^24.9.1",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.3"
  }
}
