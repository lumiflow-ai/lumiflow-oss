{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "moduleSuffixes": [""],
    "rootDirs": ["src"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
